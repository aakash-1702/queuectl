{
  "name": "queuectl",
  "version": "1.0.0",
  "description": "CLI-based background job queue system using Node.js, TypeScript, Prisma, and PostgreSQL.",
  "main": "dist/cli.js",
  "bin": {
    "queuectl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test:e2e": "ts-node test/e2e.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "queue",
    "job",
    "cli",
    "worker",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
